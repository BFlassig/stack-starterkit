APP_NAME="Stack Starter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Docker / Compose Runtime
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=stack
UID=1000
GID=1000
APP_PORT=8080
VITE_PORT=5173
VITE_HOST=0.0.0.0
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5173
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=app
DB_SSLMODE=prefer

# -----------------------------------------------------------------------------
# Session / Cache / Queue
# -----------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=redis
# CACHE_PREFIX=

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# -----------------------------------------------------------------------------
# Mail (Mailpit for local development)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# API Security / CORS
# -----------------------------------------------------------------------------
API_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,localhost:5173,127.0.0.1,127.0.0.1:8080,127.0.0.1:5173
SANCTUM_TOKEN_EXPIRATION_MINUTES=
SANCTUM_TOKEN_PREFIX=

# -----------------------------------------------------------------------------
# OpenAPI / Swagger (external API docs)
# -----------------------------------------------------------------------------
L5_SWAGGER_API_TITLE="${APP_NAME} External API"
L5_SWAGGER_USE_ABSOLUTE_PATH=true
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_OPEN_API_SPEC_VERSION=3.0.0
L5_FORMAT_TO_USE_FOR_DOCS=json
L5_SWAGGER_BASE_PATH=
L5_SWAGGER_CONST_HOST=

# -----------------------------------------------------------------------------
# Files / External Providers (fill in only when needed)
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
